# =============================================================================
# DATABASE
# Local dev: uses Docker Compose PostgreSQL
# Production: use Neon serverless PostgreSQL connection string
# =============================================================================

# Local development (Docker Compose)
DATABASE_URL="postgresql://amazon_user:amazon_pass@localhost:5432/amazon_db?schema=public"

# Production (Neon) - replace with your Neon connection string
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/amazon_db?sslmode=require"

# For Prisma migrations with Neon (use direct connection, not pooled)
# DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/amazon_db?sslmode=require"

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV="development"
PORT=3001

# JWT secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Session cookie name
SESSION_COOKIE_NAME="amazon_session_id"

# =============================================================================
# FRONTEND (prefix with VITE_ to expose to browser)
# =============================================================================
VITE_APP_NAME="Amazon Clone"

# =============================================================================
# EMAIL (Bonus feature - Resend)
# =============================================================================
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# EMAIL_FROM="noreply@your-domain.com"

# =============================================================================
# CORS
# =============================================================================
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3001"
